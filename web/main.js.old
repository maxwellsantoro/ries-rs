/**
 * RIES browser demo: load WASM, run search, render results.
 * Tries ../pkg/ (when app is at /web/) then /pkg/ (repo root). Call init() then optional initThreadPool(n) if present.
 */

// Try: same dir (web/pkg/), parent (repo pkg/), then absolute /pkg/
const PKG_CANDIDATES = [
  new URL('./pkg/ries_rs.js', import.meta.url).href,
  new URL('../pkg/ries_rs.js', import.meta.url).href,
  new URL('/pkg/ries_rs.js', import.meta.url).href,
];

let wasmModule = null;

function setStatus(message, kind = '') {
  const el = document.getElementById('status');
  el.textContent = message;
  el.className = 'status' + (kind ? ` ${kind}` : '');
}

function setSubmitEnabled(enabled) {
  document.getElementById('submit-btn').disabled = !enabled;
}

function setVersion(version) {
  const el = document.getElementById('version');
  if (el) el.textContent = `v${version}`;
}

/**
 * Load WASM: init(), then initThreadPool(n) if the build exports it (threaded build).
 */
async function initWasm() {
  setStatus('Loading WASM…', 'loading');
  let lastErr = null;
  for (const pkgUrl of PKG_CANDIDATES) {
    try {
      wasmModule = await import(/* webpackIgnore: true */ pkgUrl);
      await wasmModule.default();
      wasmModule.init();

      if (typeof wasmModule.initThreadPool === 'function') {
        const n = navigator.hardwareConcurrency || 4;
        await wasmModule.initThreadPool(n);
        setStatus(`Ready (threaded, ${n} workers).`);
      } else {
        setStatus('Ready.');
      }

      setVersion(wasmModule.version());
      setSubmitEnabled(true);
      const ph = document.getElementById('results-placeholder');
      if (ph) ph.textContent = 'Enter a target and click Search.';
      await fillPresets();
      return true;
    } catch (err) {
      lastErr = err;
      console.warn('WASM load attempt failed:', pkgUrl, err);
      continue;
    }
  }
  const msg = lastErr?.message || 'unknown';
  console.error('WASM failed to load:', lastErr);
  setStatus(
    `WASM failed: ${msg}. From repo root run: npx serve . -p 50628 then open /web/ . Or copy pkg into web/ and serve web/ .`,
    'error'
  );
  setSubmitEnabled(false);
  setPlaceholderWasmFailed();
  return false;
}

function setPlaceholderWasmFailed() {
  const ph = document.getElementById('results-placeholder');
  if (ph) ph.textContent = 'WASM did not load. See status above; check console (F12) for details.';
}

/**
 * Populate preset dropdown from listPresets().
 */
async function fillPresets() {
  if (!wasmModule || !wasmModule.listPresets) return;
  const select = document.getElementById('preset');
  if (!select) return;
  try {
    const presets = wasmModule.listPresets();
    if (!presets || typeof presets !== 'object') return;
    const names = Object.keys(presets).sort();
    for (const name of names) {
      const opt = document.createElement('option');
      opt.value = name;
      opt.textContent = name;
      select.appendChild(opt);
    }
  } catch (_) {
    // keep only "none"
  }
}

/**
 * Run search and return array of match objects.
 */
function runSearch(target, options) {
  if (!wasmModule || !wasmModule.search) throw new Error('WASM not loaded');
  return wasmModule.search(target, options);
}

function renderResults(matches) {
  const placeholder = document.getElementById('results-placeholder');
  const table = document.getElementById('results-table');
  const body = document.getElementById('results-body');

  if (!matches || matches.length === 0) {
    placeholder.classList.remove('hidden');
    placeholder.textContent = 'No matches found.';
    table.classList.add('hidden');
    table.setAttribute('aria-hidden', 'true');
    return;
  }

  placeholder.classList.add('hidden');
  table.classList.remove('hidden');
  table.removeAttribute('aria-hidden');
  body.innerHTML = '';

  for (const m of matches) {
    const row = document.createElement('tr');
    const lhs = m.lhs != null ? String(m.lhs) : '';
    const rhs = m.rhs != null ? String(m.rhs) : '';
    const equation = `${lhs} = ${rhs}`;
    const err = m.error != null ? Number(m.error) : 0;
    const complexity = m.complexity != null ? Number(m.complexity) : 0;

    const cellEq = document.createElement('td');
    cellEq.className = 'equation';
    cellEq.textContent = equation;
    const cellErr = document.createElement('td');
    cellErr.className = 'error';
    cellErr.textContent = formatError(err);
    const cellComplexity = document.createElement('td');
    cellComplexity.className = 'complexity';
    cellComplexity.textContent = String(complexity);

    row.appendChild(cellEq);
    row.appendChild(cellErr);
    row.appendChild(cellComplexity);
    body.appendChild(row);
  }
}

function formatError(err) {
  if (err === 0) return '0';
  const e = Math.abs(err);
  if (e >= 1 || e < 1e-15) return err.toExponential(2);
  return err.toExponential(2);
}

function handleSubmit(ev) {
  ev.preventDefault();
  if (!wasmModule) return;

  const targetInput = document.getElementById('target');
  const levelInput = document.getElementById('level');
  const maxMatchesInput = document.getElementById('max-matches');
  const presetSelect = document.getElementById('preset');

  const targetStr = targetInput.value.trim();
  const target = parseFloat(targetStr, 10);
  if (Number.isNaN(target)) {
    setStatus('Invalid target: enter a number.', 'error');
    return;
  }

  const level = Math.max(0, Math.min(5, parseInt(levelInput.value, 10) || 2));
  const maxMatches = Math.max(1, Math.min(100, parseInt(maxMatchesInput.value, 10) || 16));
  const presetValue = presetSelect.value.trim() || undefined;

  const options = { level, maxMatches };
  if (presetValue) options.preset = presetValue;

  setStatus('Searching…', 'loading');
  setSubmitEnabled(false);

  try {
    const results = runSearch(target, options);
    renderResults(results);
    setStatus(`Found ${results.length} match(es).`);
  } catch (err) {
    setStatus(`Search failed: ${err.message}`, 'error');
    renderResults([]);
  } finally {
    setSubmitEnabled(true);
  }
}

document.getElementById('search-form').addEventListener('submit', handleSubmit);

initWasm();
