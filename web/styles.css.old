:root {
  --bg: #0f0f12;
  --surface: #18181c;
  --border: #2a2a30;
  --text: #e4e4e7;
  --muted: #71717a;
  --accent: #a78bfa;
  --accent-hover: #c4b5fd;
  --success: #22c55e;
  --error: #ef4444;
}

* {
  box-sizing: border-box;
}

body {
  font-family: "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif;
  background: var(--bg);
  color: var(--text);
  margin: 0;
  min-height: 100vh;
  line-height: 1.5;
}

header {
  padding: 1.5rem 1rem;
  border-bottom: 1px solid var(--border);
}

header h1 {
  margin: 0;
  font-size: 1.75rem;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.tagline {
  margin: 0.25rem 0 0;
  color: var(--muted);
  font-size: 0.9rem;
}

.version {
  margin: 0.5rem 0 0;
  font-size: 0.75rem;
  color: var(--muted);
}

main {
  max-width: 52rem;
  margin: 0 auto;
  padding: 1.5rem 1rem;
}

.controls {
  margin-bottom: 1.5rem;
}

#search-form {
  display: grid;
  grid-template-columns: 1fr auto auto auto;
  gap: 1rem;
  align-items: end;
  flex-wrap: wrap;
}

@media (max-width: 640px) {
  #search-form {
    grid-template-columns: 1fr;
  }
}

.field {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.field label {
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--muted);
}

.field input,
.field select {
  padding: 0.5rem 0.6rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text);
  font-size: 0.95rem;
}

.field input:focus,
.field select:focus {
  outline: none;
  border-color: var(--accent);
}

.actions button {
  padding: 0.5rem 1rem;
  background: var(--accent);
  color: var(--bg);
  border: none;
  border-radius: 6px;
  font-weight: 500;
  cursor: pointer;
}

.actions button:hover:not(:disabled) {
  background: var(--accent-hover);
}

.actions button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.status {
  min-height: 1.5rem;
  margin-bottom: 1rem;
  font-size: 0.875rem;
  color: var(--muted);
}

.status-bar {
  padding: 0.5rem 0.75rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  min-height: 2.5rem;
}

.status.loading {
  color: var(--accent);
}

.status.error {
  color: var(--error);
}

.results h2 {
  font-size: 1rem;
  font-weight: 600;
  margin: 0 0 0.75rem;
  color: var(--muted);
}

.results-container {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
}

.placeholder {
  color: var(--muted);
  padding: 1.5rem;
  margin: 0;
}

.hidden {
  display: none;
}

#results-table {
  width: 100%;
  border-collapse: collapse;
}

#results-table th,
#results-table td {
  padding: 0.6rem 0.75rem;
  text-align: left;
  border-bottom: 1px solid var(--border);
}

#results-table th {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--muted);
  background: var(--surface);
}

#results-table tbody tr:last-child td {
  border-bottom: none;
}

#results-table .equation {
  font-family: ui-monospace, "Cascadia Code", monospace;
  font-size: 0.9rem;
}

#results-table .error {
  font-variant-numeric: tabular-nums;
  font-size: 0.85rem;
  color: var(--muted);
}

#results-table .complexity {
  font-variant-numeric: tabular-nums;
  font-size: 0.85rem;
  color: var(--muted);
}
