<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RIES — Inverse Equation Solver</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <header>
    <h1>RIES</h1>
    <p class="tagline">Find algebraic equations given their solution</p>
    <p class="version" id="version">—</p>
  </header>

  <main>
    <section class="controls">
      <form id="search-form">
        <div class="field">
          <label for="target">Target value</label>
          <input type="text" id="target" name="target" required
                 placeholder="e.g. 3.141592653589793" value="3.141592653589793">
        </div>
        <div class="field">
          <label for="level">Level (0–5)</label>
          <input type="number" id="level" name="level" min="0" max="5" value="2">
        </div>
        <div class="field">
          <label for="max-matches">Max matches</label>
          <input type="number" id="max-matches" name="maxMatches" min="1" max="100" value="16">
        </div>
        <div class="field">
          <label for="preset">Preset</label>
          <select id="preset" name="preset">
            <option value="">— none —</option>
          </select>
        </div>
        <div class="actions">
          <button type="submit" id="submit-btn" disabled>Search</button>
        </div>
      </form>
    </section>

    <section class="status status-bar" id="status" aria-live="polite">Loading WASM…</section>

    <section class="results">
      <h2>Results</h2>
      <div id="results-container">
        <p class="placeholder" id="results-placeholder">Loading… Enter a target and click Search when ready.</p>
        <table id="results-table" class="hidden" aria-hidden="true">
          <thead>
            <tr>
              <th>Equation</th>
              <th>Error</th>
              <th>Complexity</th>
            </tr>
          </thead>
          <tbody id="results-body"></tbody>
        </table>
      </div>
    </section>
  </main>

  <script type="module" src="main.js"></script>
</body>
</html>
