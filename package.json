    "type": "git",
    "url": "https://github.com/maxwellsantoro/ries-rs.git"
  },
  "bugs": {
    "url": "https://github.com/maxwellsantoro/ries-rs/issues"
  },
  "homepage": "https://github.com/maxwellsantoro/ries-rs#readme",
